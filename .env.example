# .env.example
# Copy this file to .env and fill in the values for production

# Django secret key
SECRET_KEY=your-secret-key-here

# Debug mode (False for production)
DEBUG=False

# Database configuration (Railway provides DATABASE_URL)
# Example: postgres://user:password@hostname:5432/dbname
DATABASE_URL=postgres://username:password@host:5432/dbname

# Fallback DB settings if DATABASE_URL is not set (local development)
DB_NAME=spreewise
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=your-app.railway.app,localhost,127.0.0.1

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
